{
  "name": "wongcofood-react-ts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.4.1"
  },
  "scripts": {
    "audit": "npm audit --omit=dev",
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "images:convert": "node ./scripts/convert-images.js",
    "lint": "biome lint .",
    "preview": "vite preview",
    "prepare": "husky install",
    "lint:stylex": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,css,md}": [
      "biome lint",
      "prettier --write --ignore-unknown"
    ],
    "**/*.json": [
      "biome lint",
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.2.0",
    "@fortawesome/free-brands-svg-icons": "^6.2.0",
    "@fortawesome/free-regular-svg-icons": "^6.2.0",
    "@fortawesome/free-solid-svg-icons": "^6.2.0",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@stylexjs/stylex": "^0.3.0",
    "aos": "^2.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@biomejs/biome": "^2.3.11",
    "@stylexjs/babel-plugin": "^0.3.0",
    "@stylexjs/eslint-plugin": "^0.3.0",
    "@types/aos": "^3.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^8.57.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "prettier": "3.1.0",
    "sharp": "^0.32.0",
    "typescript": "^5.3.3",
    "vite": "^6.4.1"
  }
}
